#include<iostream>
using namespace std;

int main(){
	int d1=3;
	int d2=3;
	int tahun[d1][d2];
	int penjualan[d1][d2];
	for(i=0;i<d1;i++){
		cout<<"Masukkan Tahun ke"<<i;
		cin>>tahun[i];
		for(q=0;q<d2;q++){
			cout<<"Masukkan Jumlah Penjualan ke "<<q;
			cin>>penjualan[q];
		}
	}
	for(i=0;i<d1;i++){
		cout<<i<<" "<<tahun[i];
	}
	
}
